# --- Model Hyperparameters ---
# Alpha for EMA (0.8 = Long Memory, 0.2 = Quick Adaptation)
PENALTY_SMOOTHING_FACTOR=0.8

# --- Logistics Buffers ---
# Buffer in minutes to account for rider parking/walking
RIDER_PARKING_BUFFER_MINS=2

# --- Thresholds ---
# Minimum signal gap to trigger a merchant fraud flag
FRAUD_THRESHOLD_MINS=15

# --- Data Paths ---
RAW_DATA_PATH=data/raw/
PROCESSED_DATA_PATH=data/processed/